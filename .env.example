# MiniMax 主模型和 Qwen3 Embedding 使用同一套余额。
# 接口地址、模型名、OpenAI 兼容模式和 embedding 模型名均已在代码里固定默认值。
MINIMAX_API_KEY=replace-with-real-key

# 秘塔搜索。只填密钥即可；接口地址使用代码默认值。
METASO_API_KEY=

# 通义千问 Deep Research。仅供东盟专题研究接口使用，不进入 LiveBench。
# 推荐只在 .env.local 或部署密钥里填写真实值，不要提交真实 key。
DASHSCOPE_API_KEY=
QWEN_DEEP_RESEARCH_MODEL=qwen-deep-research
QWEN_DEEP_RESEARCH_OUTPUT_FORMAT=model_summary_report
QWEN_DEEP_RESEARCH_SYNTHESIS_MODEL=qwen-plus
WORLD_ASEAN_DEEP_RESEARCH_TIMEOUT_MS=600000
WORLD_ASEAN_DEEP_RESEARCH_ANSWER_WAIT_MS=90000
WORLD_ASEAN_DEEP_RESEARCH_FALLBACK_SOURCE_MIN=8

# 东盟专题数据分析与策略模型。认证沿用 MINIMAX_API_KEY；综合长文仍由 Deep Research 输出。
WORLD_ASEAN_DECISION_MODEL_BASE_URL=https://api.scnet.cn/api/llm/v1
WORLD_ASEAN_DECISION_MODEL_ID=DeepSeek-V4-Pro
WORLD_ASEAN_DECISION_MODEL_TIMEOUT_MS=120000

# 东盟专题增量搜索。只影响 /?scene=asean 和 /api/v1/world/asean，不进入全局信源。
WORLD_ASEAN_METASO_SEARCH=1
WORLD_ASEAN_METASO_TTL_MINUTES=60
WORLD_ASEAN_METASO_QUERY_SIZE=6
WORLD_ASEAN_METASO_MAX_ITEMS=80
WORLD_ASEAN_METASO_TIMEOUT_MS=15000
# 逗号分隔域名白名单扩展，只填域名，不填协议。
WORLD_ASEAN_METASO_ALLOWED_HOSTS=

# 东盟专题公开信源、风险事件和结构化指标刷新参数。设为 0 可关闭对应模块。
WORLD_ASEAN_SOURCE_FEEDS=1
WORLD_ASEAN_SOURCE_FEED_TTL_MINUTES=60
WORLD_ASEAN_SOURCE_FEED_TIMEOUT_MS=15000
WORLD_ASEAN_SOURCE_FEED_PER_SOURCE_LIMIT=3
WORLD_ASEAN_SOURCE_FEED_LIMIT=18
WORLD_ASEAN_PUBLIC_RISK_EVENTS=1
WORLD_ASEAN_PUBLIC_RISK_TTL_MINUTES=30
WORLD_ASEAN_PUBLIC_RISK_TIMEOUT_MS=15000
WORLD_ASEAN_PUBLIC_RISK_LIMIT=40
WORLD_ASEAN_DATASET_METRICS=1
WORLD_ASEAN_DATASET_METRIC_TTL_MINUTES=180
WORLD_ASEAN_DATASET_METRIC_TIMEOUT_MS=12000
WORLD_ASEAN_DATASET_METRIC_SOURCE_LIMIT=36
WORLD_ASEAN_DATASET_METRIC_LIMIT=220
WORLD_ASEAN_DATASET_SERIES_LIMIT=160
WORLD_ASEAN_DATASET_FETCH_ATTEMPTS=3
WORLD_ASEAN_DATASET_FETCH_CONCURRENCY=2
WORLD_ASEAN_INCLUDE_EXTENDED_DATASETS=0

# 如需后台小时级增量，可让 source refresh daemon 每 60 分钟触发一次 /api/v1/world/asean?fresh=1。
# WORLD_SOURCE_REFRESH_INTERVAL_MINUTES=60
# WORLD_SOURCE_REFRESH_DAILY_SLOTS=
# 或只跑东盟专题增量：pnpm asean:refresh -- --loop --interval-minutes 60
WORLD_ASEAN_REFRESH_BASE_URL=http://127.0.0.1:5018
WORLD_ASEAN_REFRESH_INTERVAL_MINUTES=60
WORLD_ASEAN_REFRESH_LIMIT=80

# Metaculus 直连题池。未配置时 LiveBench 仍会运行，但题源健康会标记 degraded。
METACULUS_API_TOKEN=

# 可选但推荐：WorldWeave 信源监控库。保持这个 scoped 名称，
# 不要用通用 DATABASE_URL，避免与同机其它应用的数据库配置冲突。
WORLDWEAVE_DATABASE_URL=

# 独立 Docker 部署。GitHub Actions 会把完整内容保存到服务器仓库的 .env。
# 公网仅通过反向代理访问，容器端口固定为 5000，宿主机 3020 只监听回环地址。
OPENCLAW_BASE_URL=https://worldweave.tashan.chat
WORLDWEAVE_HOST_PORT=3020
WORLDWEAVE_MEM_LIMIT=2g
WORLDWEAVE_REFRESH_MEM_LIMIT=5g
WORLDWEAVE_NODE_OPTIONS=--max-old-space-size=1536
WORLDWEAVE_REFRESH_NODE_OPTIONS=--max-old-space-size=4096
WORLD_SOURCE_REFRESH_INTERVAL_MINUTES=60
WORLD_SOURCE_REFRESH_TIMEOUT_MINUTES=20

# Node 22.21+ can route built-in fetch/http/https through these proxy variables.
# Both Compose services receive them through env_file; uncomment only when the
# deployment host needs the host-side forward proxy.
# NODE_USE_ENV_PROXY=1
# HTTP_PROXY=http://host.docker.internal:1081
# HTTPS_PROXY=http://host.docker.internal:1081
# http_proxy=http://host.docker.internal:1081
# https_proxy=http://host.docker.internal:1081
# NO_PROXY=localhost,127.0.0.1,::1,host.docker.internal,worldweave,worldweave-refresh,.tashan.chat,.tashan.ac.cn
# no_proxy=localhost,127.0.0.1,::1,host.docker.internal,worldweave,worldweave-refresh,.tashan.chat,.tashan.ac.cn

# 目标服务器可直接访问外网时使用官方镜像和 npm registry。
NODE_BASE_IMAGE=node:22-slim
NPM_REGISTRY=https://registry.npmjs.org
