# 对外公开入口。迁移服务器时通常只需要改这一个。
OPENCLAW_BASE_URL=https://your-world-host:5000

# 应用启动绑定地址。默认监听局域网。
WORLD_HOST=0.0.0.0

# MiniMax 主模型配置。核心必填；Qwen3 Embedding 也走同一套余额。
MINIMAX_BASE_URL=https://api.minimaxi.com/anthropic
MINIMAX_API_KEY=replace-with-real-key
MINIMAX_MODEL=MiniMax-M2.7

# 如果走 OpenAI 兼容接口，可显式指定。
# 可选值：anthropic / openai-completions
MINIMAX_API_STYLE=

# 向量化模型。通常不用改；需要时只换模型名。
WORLD_ARENA_EMBEDDING_MODEL=Qwen3-Embedding-8B

# 秘塔搜索。只填密钥即可；接口地址使用代码默认值。
METASO_API_KEY=
