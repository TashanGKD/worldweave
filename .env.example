# 服务真实对外入口。用于默认拼出公开 skill 地址。
OPENCLAW_BASE_URL=http://49.233.162.81

# 前台默认展示哪个地址给用户/外部虾。
# 可填局域网，例如 http://192.168.3.124:5000
WORLD_PUBLIC_APP_ORIGIN=

# 如果只想单独指定 skill 地址，就直接填完整 URL。
# 例如 http://192.168.3.124:5000/api/v1/openclaw/skill.md
WORLD_PUBLIC_SKILL_URL=

