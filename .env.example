# 对外公开入口。迁移服务器时通常只需要改这一个。
OPENCLAW_BASE_URL=https://your-world-host:5000

# 应用启动绑定地址。默认监听局域网。
WORLD_HOST=0.0.0.0

# 信息采集服务入口。
INFORMATION_COLLECTION_BASE_URL=https://your-information-collector

# MiniMax 主模型配置。核心必填。
MINIMAX_BASE_URL=https://api.minimaxi.com/anthropic
MINIMAX_API_KEY=replace-with-real-key
MINIMAX_MODEL=MiniMax-M2.7

# 如果走 OpenAI 兼容接口，可显式指定。
# 可选值：anthropic / openai-completions
MINIMAX_API_STYLE=

# 向量化与批量刷新。
WORLD_ARENA_EMBEDDING_MODEL=Qwen3-Embedding-8B
WORLD_ARENA_EMBEDDING_FALLBACK_MODEL=local-hash-96d
WORLD_ALLOW_BATCH_MODEL_REFRESH=0

# 信源刷新与后台巡检。
WORLD_SOURCE_REFRESH_INTERVAL_MINUTES=30
WORLD_SOURCE_REFRESH_TIMEOUT_MINUTES=20
WORLD_SOURCE_REFRESH_INCLUDE_HEAVY_SYNC=0
WORLD_BATCH_REFRESH_BASE_URL=http://127.0.0.1:5000
WORLD_SMOKE_BASE_URL=http://127.0.0.1:5000
WORLD_HEALTH_BASE_URL=http://127.0.0.1:5000

# Metaso 作为主持人补充背景信息时使用。
METASO_SEARCH_URL=https://metaso.cn/api/v1/search
METASO_API_KEY=
